# Premier Dental Academy — environment variable EXAMPLE. Copy to .env (never commit .env).
# This static site needs NO server env to run. These document optional integrations only.
# NOTE: real secrets live in Vercel/Supabase env, never in the repo.

# ── Client-safe analytics IDs (public). Prefer assets/analytics-config.js for these. ──
GA4_MEASUREMENT_ID=
META_PIXEL_ID=
TIKTOK_PIXEL_ID=

# ── Server-side (Vercel functions / Supabase edge) — set in the platform, not here. ──
# SQUARE_ACCESS_TOKEN=        # api/enroll.js (Square payments)
# RESEND_API_KEY=             # transactional + marketing email (Resend)
# RESEND_FROM=                # e.g. "Amanda Williams <amanda@premierdentalacademyoflongview.com>" (verify domain in Resend)
# KAJABI_WEBHOOK_SECRET=      # kajabi-webhook
# SUPABASE_SERVICE_ROLE_KEY=  # edge functions + email/automation crons — NEVER client-side
# CRON_SECRET=                # random 32+ chars; Vercel Cron sends it, api/cron-* verify it
# INTERNAL_SECRET=            # optional: server-to-server calls to /api/automations-run
# MUX_TOKEN_ID=               # course video uploads (api/admin-mux-*)
# MUX_TOKEN_SECRET=           # course video uploads (api/admin-mux-*)
