# Premier Dental Academy — environment variable EXAMPLE. Copy to .env (never commit .env).
# This static site needs NO server env to run. These document optional integrations only.
# NOTE: real secrets live in Vercel/Supabase env, never in the repo.

# ── Client-safe analytics IDs (public). Prefer assets/analytics-config.js for these. ──
GA4_MEASUREMENT_ID=
META_PIXEL_ID=
TIKTOK_PIXEL_ID=

# ── Server-side (Vercel functions / Supabase edge) — set in the platform, not here. ──
# SQUARE_ACCESS_TOKEN=        # api/enroll.js (Square payments)
# RESEND_API_KEY=             # transactional email (edge functions)
# KAJABI_WEBHOOK_SECRET=      # kajabi-webhook
# SUPABASE_SERVICE_ROLE_KEY=  # edge functions only — NEVER client-side
